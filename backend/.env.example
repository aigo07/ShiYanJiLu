APP_ENV=dev
DATABASE_URL=postgresql+psycopg://shiyanjilu:shiyanjilu@localhost:5432/shiyanjilu

# Session TTL
# Preferred: seconds-based TTL for fine-grained control.
# 30 minutes = 1800
SESSION_TTL_SECONDS=1800
# Legacy (kept for backward compatibility):
# SESSION_TTL_DAYS=14

# Auth (public internet)
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
SESSION_COOKIE_NAME=sid
CSRF_COOKIE_NAME=csrf_token

# Optional: audit access token (legacy)
AUDIT_TOKEN=

APP_NAME="shiyanjilu-api"
APP_ENV="dev"

# Use docker-compose DB by default.
DATABASE_URL="postgresql+psycopg://shiyanjilu:shiyanjilu@localhost:5432/shiyanjilu"

